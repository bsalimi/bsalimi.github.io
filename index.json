[{"authors":null,"categories":null,"content":"","date":1536262749,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536262749,"objectID":"d838e662776220870765fe51a8a7367e","permalink":"www.babaksalimi.com/talk/tabl/","publishdate":"2018-09-06T12:39:09-07:00","relpermalink":"www.babaksalimi.com/talk/tabl/","section":"talk","summary":"","tags":[],"title":"Detecting Bias in Decision Support Queries","type":"talk"},{"authors":["Luke Rodriguez","Babak Salimi","Haoyue Ping","Julia Stoyanovich","Bill Howe"],"categories":null,"content":"","date":1536261655,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536261655,"objectID":"268acca07a51c37aa0e78a5322740111","permalink":"www.babaksalimi.com/publication/monility/","publishdate":"2018-09-06T12:20:55-07:00","relpermalink":"www.babaksalimi.com/publication/monility/","section":"publication","summary":"","tags":[],"title":"MobilityMirror: Bias-Adjusted Synthetic Transportation Datasets.","type":"publication"},{"authors":null,"categories":null,"content":"","date":1536208656,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536208656,"objectID":"5b9b86b51a8b62857a787cb1ace103b7","permalink":"www.babaksalimi.com/project/asha/","publishdate":"2018-09-05T21:37:36-07:00","relpermalink":"www.babaksalimi.com/project/asha/","section":"project","summary":"Asha develops a suit of techniques to enforce algorithmic fairness using causal inference and database dependencies.","tags":["Algorithmic Fairness","Causal Inference","Databse Dependancies"],"title":"Asha","type":"project"},{"authors":null,"categories":null,"content":"","date":1536208548,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536208548,"objectID":"eecb834b302a894e851cb5106334b689","permalink":"www.babaksalimi.com/project/hypdb/","publishdate":"2018-09-05T21:35:48-07:00","relpermalink":"www.babaksalimi.com/project/hypdb/","section":"project","summary":"HypDB ia a system to detect, explain, and to resolve bias in decision-support queries.","tags":["OLAP","Decision Support Systems","Causal Inference","Simpson's Paradox"],"title":"HypDB","type":"project"},{"authors":["Babak Salimi","Corey Cole","Peter Li","Johannes Gehrke","Dan Suciu"],"categories":null,"content":"[Best Demonstration Award]\n","date":1536200165,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536200165,"objectID":"394dd80e7ddf5e97272df02afd6e8eb1","permalink":"www.babaksalimi.com/publication/hypdb/","publishdate":"2018-09-05T19:16:05-07:00","relpermalink":"www.babaksalimi.com/publication/hypdb/","section":"publication","summary":"[Best Demonstration Award]","tags":[],"title":"HypDB: A Demonstration of Detecting, Explaining and Resolving Bias in OLAP queries.","type":"publication"},{"authors":["Babak Salimi, Johannes Gehrke, Dan Suciu"],"categories":null,"content":"","date":1536183183,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1536183183,"objectID":"e16d275794848b93033347b9bb2c5625","permalink":"www.babaksalimi.com/publication/biasolap/","publishdate":"2018-09-05T14:33:03-07:00","relpermalink":"www.babaksalimi.com/publication/biasolap/","section":"publication","summary":"On line analytical processing (OLAP) is an essential element of decision-support systems. OLAP tools provide insights and understanding needed for improved decision making. However, the answers to OLAP queries can be biased and lead to perplexing and incorrect insights. In this paper, we propose HypDB a system to detect, explain, and to resolve bias in decision-support queries. We give a simple definition of a biased query, which performs a set of independence tests on the data to detect bias. We propose a novel technique that gives explanations for bias, thus assisting an analyst in understanding what goes on. Additionally, we develop an automated method for rewriting a biased query into an unbiased query, which shows what the analyst intended to examine. In a thorough evaluation on several real datasets we show both the quality and the performance of our techniques, including the completely automatic discovery of the revolutionary insights from a famous 1973 discrimination case.","tags":[],"title":"Bias in OLAP Queries: Detection, Explanation, and Removal","type":"publication"},{"authors":null,"categories":null,"content":"","date":1531501959,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1531501959,"objectID":"e2b4d1e0eb19d7f6f326bf3794425376","permalink":"www.babaksalimi.com/talk/uwaff2018/","publishdate":"2018-07-13T10:12:39-07:00","relpermalink":"www.babaksalimi.com/talk/uwaff2018/","section":"talk","summary":"","tags":[],"title":"Causal Inference in Database Systems","type":"talk"},{"authors":null,"categories":null,"content":"","date":1504672645,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1504672645,"objectID":"f56affcaef95715f1026383cecbaf592","permalink":"www.babaksalimi.com/project/zaliql/","publishdate":"2017-09-05T21:37:25-07:00","relpermalink":"www.babaksalimi.com/project/zaliql/","section":"project","summary":"Causal Inference at Scale","tags":["Causal Inference","Database Systems"],"title":"ZaliQL","type":"project"},{"authors":["Babak Salimi","Corey Cole","Dan R. K. Ports","Dan Suciu"],"categories":null,"content":"","date":1501985777,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1501985777,"objectID":"d2880e4820bb093c3281b3e819d38506","permalink":"www.babaksalimi.com/publication/zaliql/","publishdate":"2017-08-05T19:16:17-07:00","relpermalink":"www.babaksalimi.com/publication/zaliql/","section":"publication","summary":"","tags":[],"title":"ZaliQL: causal inference from observational data at scale","type":"publication"}]